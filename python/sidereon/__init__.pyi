class SelectionError(SidereonError):
    """Raised when product-staleness selection cannot satisfy a request (empty
    set, no prior product, beyond the staleness cap, or an invalid
    range/policy/product)."""

class FallbackError(SidereonError):
    """Raised when a precise-with-broadcast fallback solve fails (the selected
    precise solve failed, or the broadcast fallback solve failed)."""

class DegradationKind(enum.Enum):
    """How a selected product's source epoch relates to the requested epoch."""

    EXACT = ...
    NEAREST_PRIOR = ...
    DIURNAL_SHIFT = ...
    @property
    def label(self) -> str: ...
    @property
    def is_exact(self) -> bool: ...
    def __repr__(self) -> str: ...

class StalenessMetadata:
    """The product staleness behind a selection result; epochs are J2000
    seconds and `staleness_s` is `requested - source` (never negative)."""

    @property
    def kind(self) -> DegradationKind: ...
    @property
    def requested_epoch_j2000_s(self) -> float: ...
    @property
    def source_epoch_j2000_s(self) -> float: ...
    @property
    def staleness_s(self) -> float: ...
    @property
    def staleness_days(self) -> float: ...
    def __repr__(self) -> str: ...

