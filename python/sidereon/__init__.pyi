    """A built-once fleet of parsed TLEs for repeated batch geometry.

    Built from already-parsed `Tle` objects (no parsing or I/O); owns its
    satellites and borrows them on each call, so one instance drives a live
    scene across frames. Fleet order is preserved: it is the leading axis of
    `propagate` and the `satellite_index` of every `FleetPass`.
    """

    def __init__(self, satellites: Sequence[Tle]) -> None: ...
    @property
    def satellite_count(self) -> int: ...
    @property
    def catalog_numbers(self) -> list[str]: ...
    def propagate(self, epochs_unix_us: npt.NDArray[np.int64]) -> BatchPropagation: ...
    def visible(
        self,
        station: GroundStation,
        epoch_unix_us: int,
        min_elevation_deg: float = ...,
    ) -> list[VisibleSatellite]: ...
    def look_angle_arcs(
        self, station: GroundStation, epochs_unix_us: npt.NDArray[np.int64]
    ) -> list[LookAngles]: ...
    def ground_tracks(
        self, epochs_unix_us: npt.NDArray[np.int64]
    ) -> list[GroundTrack]: ...
    def passes(
        self,
        station: GroundStation,
        start_unix_us: int,
        end_unix_us: int,
        *,
        elevation_mask_deg: float = ...,
        step_seconds: float = ...,
        time_tolerance_s: float = ...,
    ) -> list[FleetPass]: ...
    def __len__(self) -> int: ...
    def __repr__(self) -> str: ...

