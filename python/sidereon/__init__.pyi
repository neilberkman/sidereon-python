"""Type stubs for the Sidereon Python bindings."""

import enum
import os
from typing import Any, Mapping, Sequence

import numpy as np
import numpy.typing as npt

class SidereonError(Exception):
    """Base class for every Sidereon domain failure."""

class ParseError(SidereonError):
    """Base class for input-format parse failures (SP3, TLE, ...)."""

class Sp3ParseError(ParseError):
    """Raised when an SP3 precise-ephemeris product fails to parse."""

class AntexParseError(ParseError):
    """Raised when an ANTEX antenna product fails to parse."""

class TleParseError(ParseError):
    """Raised when a two-line element set fails to parse or initialize SGP4."""

class SolveError(SidereonError):
    """Raised when a solve or propagation fails (non-convergence, SGP4 error
    code, or integration failure)."""

class RinexNavParseError(ParseError):
    """Raised when a RINEX navigation file fails to parse."""

class RinexObsParseError(ParseError):
    """Raised when a RINEX observation file fails to parse."""

class RinexClockParseError(ParseError):
    """Raised when a RINEX clock file fails strict parsing."""

class CrinexParseError(ParseError):
    """Raised when a Compact RINEX observation file fails to decode."""

class IonexParseError(ParseError):
    """Raised when an IONEX ionosphere-map product fails to parse."""

class SpkParseError(ParseError):
    """Raised when a JPL/NAIF SPK (DAF .bsp) ephemeris kernel fails to parse."""

class RtcmParseError(ParseError):
    """Raised when an RTCM 3 message body cannot be decoded or framed."""

class ConstellationError(SidereonError):
    """Raised when the GNSS constellation catalog cannot be built or validated."""

